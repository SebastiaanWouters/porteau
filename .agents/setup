#!/usr/bin/env bash
set -euo pipefail

readonly VP_HOME="${VP_HOME:-${HOME}/.vite-plus}"
export PATH="${VP_HOME}/bin:${PATH}"

if ! command -v vp >/dev/null 2>&1; then
  echo 'Installing Vite+...'
  curl --fail --location --silent --show-error https://vite.plus |
    CI=1 VP_NODE_MANAGER=yes bash
fi

echo 'Installing the Vite+ environment and dependencies...'
CI=1 vp install --frozen-lockfile

echo 'Orb setup complete.'
