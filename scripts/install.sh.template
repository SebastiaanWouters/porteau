#!/usr/bin/env bash
# shellcheck disable=SC2317
main() {
set -Eeuo pipefail
YES=0 CHECK=0 DEPENDENCIES_ONLY=0 TMP=''
PORTEAU_VERSION='@PORTEAU_VERSION@'
PORTEAU_REGISTRY='@PORTEAU_REGISTRY@'
PORTEAU_PREFIX="${HOME:-}/.local"
PORTEAU_BIN="$PORTEAU_PREFIX/bin/porteau"
cleanup() { if [[ -n "$TMP" ]]; then rm -rf -- "$TMP"; fi; }
trap cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT TERM
usage() { printf '%s\n' 'Usage: ./install.sh [--check] [--yes] [--dependencies-only] [--help]' '  --dependencies-only  Check/install Node and native tools, but not Porteau'; }
while (( $# )); do
  case "$1" in --check) CHECK=1 ;; --yes) YES=1 ;; --dependencies-only) DEPENDENCIES_ONLY=1 ;; --help|-h) usage; exit 0 ;; *) usage >&2; exit 2 ;; esac
  shift
done
(( CHECK && YES )) && { echo '--check and --yes cannot be used together.' >&2; exit 2; }
[[ -r /etc/os-release ]] || { echo 'Unsupported system: missing /etc/os-release' >&2; exit 1; }
# shellcheck disable=SC1091
. /etc/os-release
[[ "${ID:-}" == ubuntu ]] || { echo 'Automatic setup supports Ubuntu only.' >&2; exit 1; }
ARCH="$(dpkg --print-architecture)"; ASSET='' URL='' SIZE='' SHA=''
case "${VERSION_ID:-}/${VERSION_CODENAME:-}/$ARCH" in
# @ASSET_CASES@
  *) echo 'Supported targets: @SUPPORTED_TARGET_DESCRIPTION@.' >&2; exit 1 ;;
esac
tool_version() { local v; command -v "$1" >/dev/null 2>&1 || return 1; v="$($1 --version 2>&1)"; [[ "$v" =~ ^$1\ v([0-9]+\.[0-9]+\.[0-9]+-[0-9]+),\ built\ against\ [^$'\r\n']+(\ with\ SSL\ support)?$ ]] || return 1; printf '%s' "${BASH_REMATCH[1]}"; }
version_at_least() { [[ -n "$1" ]] && dpkg --compare-versions "$1" ge "$2"; }
machine_ok() { local help; help="$("$1" --help 2>&1)" && [[ "$help" == *--machine-log-json* ]]; }
tool_pair_ok() { version_at_least "$1" '@MYDUMPER_MINIMUM_VERSION@' && version_at_least "$2" '@MYLOADER_MINIMUM_VERSION@' && [[ "$1" == "$2" ]] && machine_ok mydumper && machine_ok myloader; }
node_ok() { local npm_version; command -v node >/dev/null 2>&1 && command -v npm >/dev/null 2>&1 && node -e 'const a=process.versions.node.split(".").map(Number),m="@MINIMUM_NODE_VERSION@".split(".").map(Number);process.exit(a[0]>m[0]||(a[0]===m[0]&&(a[1]>m[1]||(a[1]===m[1]&&a[2]>=m[2])))?0:1)' && npm_version="$(npm --version 2>/dev/null)" && [[ "$npm_version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] ; }
porteau_ok() {
  local package="$PORTEAU_PREFIX/lib/node_modules/porteau/package.json" expected launcher
  [[ -f "$package" && ! -L "$package" && -x "$PORTEAU_BIN" ]] || return 1
  [[ "$(node -e 'const p=require(process.argv[1]);process.stdout.write(p.name+"@"+p.version+" "+p.bin.porteau)' "$package" 2>/dev/null)" == "porteau@$PORTEAU_VERSION dist/cli.mjs" ]] || return 1
  expected="$(readlink -f "$PORTEAU_PREFIX/lib/node_modules/porteau/dist/cli.mjs")"
  launcher="$(readlink -f "$PORTEAU_BIN")"
  [[ -n "$expected" && "$launcher" == "$expected" && "$("$PORTEAU_BIN" --version 2>/dev/null)" == "$PORTEAU_VERSION" ]]
}
validate_user_prefix() {
  [[ -n "${HOME:-}" && "$HOME" == /* && "$HOME" != / && "$HOME" != *$'\n'* ]] || { echo 'HOME must be a sane absolute path for a user-owned Porteau installation.' >&2; return 1; }
  (( EUID != 0 )) || { echo 'Run as your normal user; the installer invokes sudo only for disclosed system packages.' >&2; return 1; }
  local path owner
  for path in "$HOME" "$PORTEAU_PREFIX"; do
    [[ -e "$path" || -L "$path" ]] || continue
    [[ -d "$path" && ! -L "$path" ]] || { echo "$path must be an existing real directory." >&2; return 1; }
    owner="$(stat -c %u "$path")"; [[ "$owner" == "$EUID" ]] || { echo "$path must be owned by the current user." >&2; return 1; }
    [[ -w "$path" && -x "$path" ]] || { echo "$path must be writable by the current user." >&2; return 1; }
  done
}
verify_release() {
  case ":$PATH:" in *":$PORTEAU_PREFIX/bin:"*) ;; *) echo "Add Porteau to this shell with: export PATH=\"$PORTEAU_PREFIX/bin:\$PATH\"" ;; esac
  porteau_ok || { echo 'Porteau package or launcher verification failed.' >&2; return 1; }
  [[ -n "$TMP" ]] || TMP="$(mktemp -d)"
  (cd "$TMP" && env -u PORTEAU_MYDUMPER -u PORTEAU_MYLOADER "$PORTEAU_BIN" doctor --no-interactive >/dev/null) || { echo 'Porteau doctor verification failed.' >&2; return 1; }
}
(( ! DEPENDENCIES_ONLY && ! CHECK )) && validate_user_prefix
NODE=0 TOOLS=0 PORTEAU=0; node_ok || NODE=1
MYDUMPER_VERSION="$(tool_version mydumper || true)"
MYLOADER_VERSION="$(tool_version myloader || true)"
tool_pair_ok "$MYDUMPER_VERSION" "$MYLOADER_VERSION" || TOOLS=1
(( ! DEPENDENCIES_ONLY )) && { porteau_ok || PORTEAU=1; }
BLOCKED_DOWNGRADE=0
if (( TOOLS )) && { { [[ -n "$MYDUMPER_VERSION" ]] && dpkg --compare-versions "$MYDUMPER_VERSION" gt '@ENGINE_VERSION@'; } || { [[ -n "$MYLOADER_VERSION" ]] && dpkg --compare-versions "$MYLOADER_VERSION" gt '@ENGINE_VERSION@'; }; }; then BLOCKED_DOWNGRADE=1; fi
echo 'Porteau installation plan'
if (( NODE )); then
  echo '  Node.js target: @NODE_TARGET_MAJOR@ from the third-party NodeSource repository'
  echo '  Signing key: @NODE_SOURCE_KEY_URL@'
  echo '  Required fingerprint: @NODE_SOURCE_FINGERPRINT@'
  echo '  Repository: @NODE_SOURCE_REPOSITORY@'
  echo '  sudo install -m 0644 <verified-keyring> @NODE_SOURCE_KEYRING@'
  echo '  sudo install -m 0644 <verified-source-list> @NODE_SOURCE_LIST@'
  echo '  sudo apt-get update'
  echo '  Validate with: apt-cache madison nodejs (require NodeSource node_@NODE_TARGET_MAJOR@.x and major @NODE_TARGET_MAJOR@)'
  echo '  sudo env DEBIAN_FRONTEND=noninteractive apt-get install --yes nodejs=<validated NodeSource @NODE_TARGET_MAJOR@ candidate>'
fi
if (( TOOLS )); then
  echo "  Native package: $URL"
  echo "  Required size: $SIZE; required SHA-256: $SHA"
  echo "  sudo env DEBIAN_FRONTEND=noninteractive apt-get install --yes ./$ASSET (from the verified temporary directory)"
fi
if (( PORTEAU )); then
  echo "  CLI package: porteau@$PORTEAU_VERSION from $PORTEAU_REGISTRY"
  echo "  npm view --registry $PORTEAU_REGISTRY --userconfig <temporary>/npmrc --cache <temporary>/npm-cache --json porteau@$PORTEAU_VERSION version"
  echo "  npm install --global --prefix $PORTEAU_PREFIX --ignore-scripts --no-audit --no-fund --registry $PORTEAU_REGISTRY --userconfig <temporary>/npmrc --cache <temporary>/npm-cache porteau@$PORTEAU_VERSION"
  echo '  npm uses temporary cache/config and never sudo; sudo is limited to the APT/keyring commands above.'
elif (( DEPENDENCIES_ONLY )); then
  echo '  Dependencies-only: Porteau will not be checked or installed'
fi
for marker in NVM_DIR ASDF_DIR MISE_DATA_DIR VOLTA_HOME; do [[ -n "${!marker:-}" ]] && echo "  Warning: user-managed Node detected ($marker); system Node will not replace its shims."; done
(( BLOCKED_DOWNGRADE )) && { echo "Automatic setup will not downgrade detected native tools ($MYDUMPER_VERSION / $MYLOADER_VERSION) to @ENGINE_VERSION@; install a matching supported pair manually." >&2; exit 1; }
if (( ! NODE && ! TOOLS && DEPENDENCIES_ONLY )); then
  echo 'All dependencies are compatible.'; exit 0
fi
if (( ! NODE && ! TOOLS && ! PORTEAU )); then
  verify_release || exit 1
  echo "Porteau $PORTEAU_VERSION and all dependencies are ready."
  exit 0
fi
(( CHECK )) && { echo 'Check only: no changes made.'; exit 1; }
if (( ! YES )); then
  { : </dev/tty && : >/dev/tty; } 2>/dev/null || { echo 'No TTY: refusing mutation without --yes.' >&2; exit 1; }
  printf 'Proceed? [y/N] ' >/dev/tty; read -r answer </dev/tty || true
  [[ "$answer" == y || "$answer" == Y ]] || { echo 'Cancelled; install dependencies manually or rerun with --yes.'; exit 0; }
fi
TMP="$(mktemp -d)"
mkdir -m 0700 "$TMP/npm-cache"
printf 'ignore-scripts=true\n' >"$TMP/npmrc"
if (( TOOLS )); then
  curl --proto '=https' --proto-redir '=https' --fail --location --silent --show-error "$URL" --output "$TMP/$ASSET"
  [[ "$(stat -c %s "$TMP/$ASSET")" == "$SIZE" ]] || { echo 'Package size mismatch.' >&2; exit 1; }
  echo "$SHA  $TMP/$ASSET" | sha256sum --check --status || { echo 'Package checksum mismatch.' >&2; exit 1; }
fi
if (( NODE )); then
  command -v gpg >/dev/null 2>&1 || { echo 'gpg is required to verify the NodeSource signing key; install gnupg manually.' >&2; exit 1; }
  curl --proto '=https' --proto-redir '=https' --fail --location --silent --show-error '@NODE_SOURCE_KEY_URL@' --output "$TMP/nodesource.asc"
  KEY_INFO="$(gpg --batch --show-keys --with-colons "$TMP/nodesource.asc")"
  KEY_FINGERPRINTS="$(awk -F: '$1=="pub"{primary=1;next} $1=="sub"{primary=0;next} $1=="fpr"&&primary{print $10;primary=0}' <<<"$KEY_INFO")"
  [[ "$KEY_FINGERPRINTS" == '@NODE_SOURCE_FINGERPRINT@' ]] || { echo 'NodeSource key fingerprint mismatch.' >&2; exit 1; }
  gpg --batch --dearmor --output "$TMP/nodesource.gpg" "$TMP/nodesource.asc"
  KEYRING_INFO="$(gpg --batch --show-keys --with-colons "$TMP/nodesource.gpg")"
  KEYRING_FINGERPRINTS="$(awk -F: '$1=="pub"{primary=1;next} $1=="sub"{primary=0;next} $1=="fpr"&&primary{print $10;primary=0}' <<<"$KEYRING_INFO")"
  [[ "$KEYRING_FINGERPRINTS" == '@NODE_SOURCE_FINGERPRINT@' ]] || { echo 'Generated NodeSource keyring fingerprint mismatch.' >&2; exit 1; }
  printf '%s\n' '@NODE_SOURCE_REPOSITORY@' >"$TMP/nodesource.list"
  sudo install -m 0644 "$TMP/nodesource.gpg" '@NODE_SOURCE_KEYRING@'
  sudo install -m 0644 "$TMP/nodesource.list" '@NODE_SOURCE_LIST@'
  sudo apt-get update
  CANDIDATE="$(apt-cache madison nodejs | awk -F'|' '{for(i=1;i<=3;i++)gsub(/^[[:space:]]+|[[:space:]]+$/, "", $i)} $1=="nodejs" && $2 ~ /^@NODE_TARGET_MAJOR@\./ && index($3,"https://deb.nodesource.com/node_@NODE_TARGET_MAJOR@.x")==1 {print $2; exit}')"
  [[ -n "$CANDIDATE" ]] || { echo 'NodeSource did not provide a Node.js @NODE_TARGET_MAJOR@ candidate.' >&2; exit 1; }
  sudo env DEBIAN_FRONTEND=noninteractive apt-get install --yes "nodejs=$CANDIDATE"
fi
if (( PORTEAU )); then
  PUBLISHED_VERSION="$(npm view --registry "$PORTEAU_REGISTRY" --userconfig "$TMP/npmrc" --cache "$TMP/npm-cache" --json "porteau@$PORTEAU_VERSION" version 2>/dev/null | tr -d '"[:space:]')"
  [[ "$PUBLISHED_VERSION" == "$PORTEAU_VERSION" ]] || { echo "porteau@$PORTEAU_VERSION is not available from the expected registry." >&2; exit 1; }
fi
(( TOOLS )) && (cd "$TMP" && sudo env DEBIAN_FRONTEND=noninteractive apt-get install --yes "./$ASSET")
if (( PORTEAU )); then
  npm install --global --prefix "$PORTEAU_PREFIX" --ignore-scripts --no-audit --no-fund --registry "$PORTEAU_REGISTRY" --userconfig "$TMP/npmrc" --cache "$TMP/npm-cache" "porteau@$PORTEAU_VERSION"
fi
MYDUMPER_VERSION="$(tool_version mydumper || true)"
MYLOADER_VERSION="$(tool_version myloader || true)"
if ! node_ok || ! tool_pair_ok "$MYDUMPER_VERSION" "$MYLOADER_VERSION"; then
  echo 'Post-install dependency verification failed.' >&2
  exit 1
fi
if (( ! DEPENDENCIES_ONLY )); then
  verify_release || exit 1
  echo "Porteau $PORTEAU_VERSION and all dependencies installed and verified."
else
  echo 'Dependencies installed and verified.'
fi
}
{ main "$@"; }
