{
  "name": "porteau",
  "version": "0.1.0-alpha.7",
  "description": "Safe, observable MySQL logical backups and restores with mydumper and myloader",
  "keywords": [
    "mysql",
    "backup",
    "restore",
    "mydumper",
    "myloader",
    "cli"
  ],
  "homepage": "https://github.com/SebastiaanWouters/porteau#readme",
  "bugs": "https://github.com/SebastiaanWouters/porteau/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebastiaanWouters/porteau.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "bump": "node scripts/bump-version.mjs",
    "generate:install": "tsx scripts/generate-install-script.ts",
    "package:smoke": "node scripts/package-smoke.mjs",
    "porteau": "vp pack && node dist/cli.mjs",
    "verify": "bash scripts/check-shell.sh && vp check && vp test && vp pack && vp run package:smoke",
    "verify:external": "bash scripts/verify-external.sh",
    "package:dry-run": "vp run verify && pnpm publish --dry-run --no-git-checks"
  },
  "bin": {
    "porteau": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "dependencies": {
    "@clack/prompts": "1.7.0",
    "c12": "3.3.4",
    "consola": "3.4.2",
    "mysql2": "3.23.0",
    "nostics": "1.2.0",
    "valibot": "1.4.2"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5",
    "vite-plus": "0.2.5"
  }
}
